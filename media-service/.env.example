PORT=3004
NODE_ENV=development

# local | s3
MEDIA_STORAGE_BACKEND=local
MEDIA_STORAGE_ROOT=media-data
MEDIA_PUBLIC_BASE_URL=http://127.0.0.1:3004
MEDIA_SIGNING_SECRET=dev-media-signing-secret

INTERNAL_SERVICE_KEY=dev-internal-key

# S3 backend (when MEDIA_STORAGE_BACKEND=s3)
MEDIA_S3_BUCKET=
MEDIA_S3_ENDPOINT=
MEDIA_S3_REGION=auto
